# syntax=docker/dockerfile:1.7
#
# paperless-ngx + paperless-paddleocr (vl-remote engine).
# Layout analysis runs locally on CPU; VLM recognition is delegated to a
# separate `paddleocr-genai-vllm-server` container - see
# docker-compose.vl-remote.yml for the matching runtime config.
#
# Build:
#   docker build \
#     --build-arg PLUGIN_REF=v0.1.0 \
#     -f examples/Dockerfile.vl-remote \
#     -t paperless-paddleocr:vl-remote .

ARG PLUGIN_REF=master
ARG PAPERLESS_TAG=beta

# --- Stage 1: build the plugin wheel from source --------------------------
FROM python:3.12-slim AS plugin
ARG PLUGIN_REF
ADD https://github.com/flobernd/paperless-paddleocr.git#${PLUGIN_REF} /src
WORKDIR /src
RUN pip install --no-cache-dir build \
 && python -m build --wheel --outdir /dist

# --- Stage 2: layer the plugin + CPU paddle onto paperless-ngx ------------
FROM ghcr.io/paperless-ngx/paperless-ngx:${PAPERLESS_TAG}

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      libgl1 \
      libglib2.0-0 \
      libsm6 \
      libxext6 \
      libxrender1 \
      libgomp1 \
 && rm -rf /var/lib/apt/lists/*

COPY --from=plugin /dist/*.whl /tmp/plugin/
RUN pip install --no-cache-dir "paddlepaddle>=3.0" \
 && WHEEL=$(ls /tmp/plugin/*.whl) \
 && pip install --no-cache-dir "${WHEEL}[vl]" \
 && rm -rf /tmp/plugin

ENV PAPERLESS_PADDLEOCR_ENGINE=vl-remote
